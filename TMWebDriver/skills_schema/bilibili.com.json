  "get_video_list": {
    "js": "(function(){var items=[];var links=document.querySelectorAll('a[href*=\"bilibili.com/video/\"]');var seen={};links.forEach(function(a){var href=a.href.split('?')[0];if(href&&!seen[href]){seen[href]=true;items.push({title:(a.title||a.textContent.trim()).substring(0,80),link:href});}});return JSON.stringify(items);})()",
    "description": "获取页面上所有B站视频链接和标题",
